# Backend (safe-qr-back: npm run dev, porta 3000).
#
# Android: 127.0.0.1 = o próprio celular, NÃO o PC. Use:
#   - Emulador → http://10.0.2.2:3000
#   - Aparelho físico (mesma Wi‑Fi) → http://<IP-do-PC>:3000 (o log do npm run dev mostra esse IP)
# Web / Windows / iOS Simulator → http://127.0.0.1:3000
API_BASE_URL=http://192.168.100.20:3000
# API_BASE_URL=http://10.0.2.2:3000
# API_BASE_URL=http://127.0.0.1:3000

# remote = POST /v1/qr/analyze no API_BASE_URL | local = só heurística no aparelho
ANALYZE_MODE=remote
API_CONNECT_TIMEOUT_MS=20000
API_RECEIVE_TIMEOUT_MS=20000
THEME_PERSISTENCE_KEY=safe_qr_theme_mode
