# GCP
GCP_PROJECT_ID=safe-qr-app-xxxxx
GOOGLE_APPLICATION_CREDENTIALS=./credentials/safe-qr-pubsub-consumer.json

# Pub/Sub (consumidor — pull + ack)
PUBSUB_SUBSCRIPTION=safe-qr-analyze-events-sub
CONSUMER_ENABLED=true
CONSUMER_MAX_MESSAGES=10
CONSUMER_ACK_DEADLINE_SEC=60

# Firestore (scan_events) — credencial SEPARADA da SA Pub/Sub (precisa Cloud Datastore User)
FIRESTORE_ENABLED=true
FIRESTORE_COLLECTION=scan_events
# Opção A (rápida): reutilizar JSON Firebase do back (já lê/escreve Firestore)
FIREBASE_GOOGLE_APPLICATION_CREDENTIALS=../safe_qr_back/safe-qr-app-dbc39536954e.json
# Opção B (ideal): mesma SA consumer + role roles/datastore.user no IAM
# FIREBASE_GOOGLE_APPLICATION_CREDENTIALS=./credentials/safe-qr-pubsub-consumer.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Runtime
NODE_ENV=development
LOG_LEVEL=info
